# Flask
FLASK_ENV=development
SECRET_KEY=change-me

# JWT
JWT_SECRET_KEY=change-me-too

# SQLite DB (stored under backend/instance/)
DATABASE_URL=sqlite:///hotel_reservation.db

# CORS (frontend dev server)
CORS_ORIGINS=http://localhost:5173

# OpenAI (server-side only; do not expose this key in the frontend)
OPENAI_API_KEY="your api key"
# Example models: gpt-4.1-mini (fast/cheap) or gpt-4.1 (higher quality)
OPENAI_MODEL=gpt-4.1-mini
